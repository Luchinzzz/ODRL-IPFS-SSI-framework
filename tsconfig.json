{
    "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "outDir": "./build",
      "rootDir": ".",
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "skipLibCheck": true
    },
     "include": ["/**/*"],
    "exclude": ["node_modules"],
    "$schema": "https://json.schemastore.org/tsconfig"
  }